{
  "name": "ask-bonk",
  "version": "0.2.0",
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "build": "flue build --target cloudflare",
    "deploy": "flue build --target cloudflare && wrangler deploy --config dist/ask_bonk/wrangler.json --var BONK_VERSION:\"$(git describe --tags --always)\" --var BONK_COMMIT:\"$(git rev-parse --short HEAD)\"",
    "dev": "flue dev --target cloudflare",
    "test": "vitest",
    "typecheck:action": "tsc --noEmit -p tsconfig.github-action.json",
    "cf-typegen": "wrangler types",
    "cli:build": "bun build cli/index.ts --compile --outfile cli/bonk",
    "cli": "bun run cli/index.ts",
    "lint": "oxlint",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "@flue/github": "^1.0.0-beta.1",
    "@flue/runtime": "^1.0.0-beta.9",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/plugin-retry": "^8.1.0",
    "@octokit/plugin-throttling": "^11.0.3",
    "@octokit/rest": "^22.0.1",
    "agents": "^0.17.4",
    "ai": "^7.0.26",
    "better-result": "^2.9.2",
    "hono": "4.12.30",
    "jose": "^6.2.3",
    "shescape": "^3.0.0",
    "ulid": "^3.0.2",
    "valibot": "^1.4.2"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@flue/cli": "^1.0.0-beta.9",
    "@octokit/webhooks-types": "^7.6.1",
    "@types/node": "^26.1.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "typescript": "^7.0.2",
    "vitest": "~4.1.10",
    "wrangler": "^4.110.0"
  },
  "overrides": {
    "hono": "4.12.30"
  }
}
