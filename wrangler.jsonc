{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ask-bonk",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-16",
  "rules": [
    {
      "type": "Text",
      "globs": ["**/*.hbs", "**/*.hbs?raw", "**/*.sql", "**/*.sql?raw"],
      "fallthrough": true,
    },
  ],
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "traces": {
      "enabled": true,
      "head_sampling_rate": 0.1,
    },
  },
  "vars": {
    // Default model for OpenCode sessions
    "DEFAULT_MODEL": "opencode/claude-opus-4-5",
    "BONK_VERSION": "dev",
    "BONK_COMMIT": "unknown",
    // Allowed orgs/users for GitHub App installation
    "ALLOWED_ORGS": ["elithrar", "cloudflare", "ask-bonk", "replicate", "emdash-cms", "Cloudflare-Studio"],
  },
  "durable_objects": {
    "bindings": [
      {
        "class_name": "RepoAgent",
        "name": "REPO_AGENT",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v4",
      "new_sqlite_classes": ["RepoAgent", "Sandbox"],
    },
    {
      "tag": "v5",
      "new_sqlite_classes": ["FlueRegistry", "FlueControlPlaneAgent"],
    },
    {
      "tag": "v6",
      "deleted_classes": ["Sandbox"],
    },
    {
      "tag": "v7",
      "new_sqlite_classes": [
        "FlueGithubSetupWorkflow",
        "FlueGithubTrackWorkflow",
        "FlueGithubFinalizeWorkflow",
      ],
    },
  ],
  "kv_namespaces": [
    {
      "binding": "APP_INSTALLATIONS",
      "id": "03ef4765c3824caf9fb9b8ac31584f38",
    },
  ],
  // Rate limiter for issues events from non-write users: 5 requests per minute
  "ratelimits": [
    {
      "name": "RATE_LIMITER",
      "namespace_id": "1001",
      "simple": {
        "limit": 5,
        "period": 60,
      },
    },
  ],
  "analytics_engine_datasets": [
    {
      "binding": "BONK_EVENTS",
      "dataset": "bonk_events",
    },
  ],
}
