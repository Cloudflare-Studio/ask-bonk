{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ask-bonk",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-16",
  "rules": [
    {
      "type": "Text",
      "globs": ["**/*.hbs", "**/*.hbs?raw", "**/*.sql", "**/*.sql?raw"],
      "fallthrough": true,
    },
  ],
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
  },
}
